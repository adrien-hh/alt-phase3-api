# =============================================
# DEVELOPMENT NOTES
# =============================================
# Start MySQL only: docker-compose up mysql
# Start PostgreSQL only: docker-compose up postgres
# With admin tools: docker-compose --profile admin-tools up mysql phpmyadmin
# Reset everything: docker-compose down -v && docker-compose up